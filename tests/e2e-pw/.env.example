# ─────────────────────────────────────────────────────────────────────────────
# UnoPim Playwright API tests — environment configuration
#
# Copy to `.env`, fill in, then `export $(grep -v '^#' .env | xargs)` before
# running tests. Alternatively, drop credentials into
# `tests/e2e-pw/.api-config.json` (the suite reads both, env vars win).
# ─────────────────────────────────────────────────────────────────────────────

# ── Target environment ──────────────────────────────────────────────────────
API_BASE_URL=http://127.0.0.1:8000
# Falls back to BASE_URL if API_BASE_URL is unset.
BASE_URL=http://127.0.0.1:8000

# ── Admin login (used by global-setup AND first-run credential bootstrap) ───
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
API_INTEGRATION_NAME=UnoPim API Test Integration

# ── OAuth2 client credentials ───────────────────────────────────────────────
# Either set these directly, or leave blank and the suite will auto-create an
# integration via Chromium on first run and persist the result to
# `tests/e2e-pw/.api-config.json`.
API_CLIENT_ID=
API_CLIENT_SECRET=
API_USERNAME=admin@example.com
API_PASSWORD=admin123

# ── Seed-data overrides ─────────────────────────────────────────────────────
# Only override these when your install ships different seed codes.
API_ROOT_CATEGORY=root
API_DEFAULT_LOCALE=en_US
API_SECONDARY_LOCALE=fr_FR
API_DEFAULT_CHANNEL=default
API_DEFAULT_CURRENCY=USD
API_DEFAULT_FAMILY=default

# ── Configurable / Variant test overrides ───────────────────────────────────
# Super-attributes must already exist in the product's family. UnoPim's
# default install ships `color` and `size` in the `default` family — change
# these if your install differs.
API_CONFIGURABLE_PATH=/configurable-products
API_SUPER_ATTRS=color,size
API_VARIANT_COLOR_ATTR=color
API_VARIANT_SIZE_ATTR=size

# ── CI flag ─────────────────────────────────────────────────────────────────
# Truthy enables: html-report=never-open, retries=1, forbidOnly=true.
CI=
