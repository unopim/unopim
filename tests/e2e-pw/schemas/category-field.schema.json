{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Category Field",
  "type": "object",
  "required": ["code", "type"],
  "properties": {
    "code": { "type": "string" },
    "type": { "type": "string" },
    "status": { "type": ["integer", "boolean"] },
    "position": { "type": ["integer", "string"] },
    "is_required": { "type": ["boolean", "integer"] },
    "is_unique": { "type": ["boolean", "integer"] },
    "value_per_locale": { "type": ["boolean", "integer"] },
    "validation": { "type": ["string", "null"] },
    "regex_pattern": { "type": ["string", "null"] },
    "section": { "type": ["string", "null"] },
    "enable_wysiwyg": { "type": ["boolean", "integer"] },
    "labels": { "type": ["object", "null"] }
  }
}
