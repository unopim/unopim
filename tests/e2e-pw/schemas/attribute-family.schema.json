{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Attribute Family",
  "type": "object",
  "required": ["code"],
  "properties": {
    "code": { "type": "string" },
    "labels": { "type": ["object", "null"] },
    "attribute_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "type": "string" },
          "position": { "type": ["integer", "string"] },
          "custom_attributes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code"],
              "properties": {
                "code": { "type": "string" },
                "position": { "type": ["integer", "string"] }
              }
            }
          }
        }
      }
    }
  }
}
