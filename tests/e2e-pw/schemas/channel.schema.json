{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Channel",
  "type": "object",
  "required": ["code"],
  "properties": {
    "code": { "type": "string", "minLength": 1 },
    "labels": { "type": "object" },
    "root_category": { "type": ["string", "null"] },
    "locales": { "type": "array", "items": { "type": "string" } },
    "currencies": { "type": "array", "items": { "type": "string" } }
  }
}
