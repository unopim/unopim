{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Configurable Product",
  "type": "object",
  "required": ["sku"],
  "properties": {
    "sku": { "type": "string" },
    "type": { "type": "string" },
    "family": { "type": ["string", "null"] },
    "status": { "type": ["boolean", "integer"] },
    "super_attributes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "variants": {
      "type": ["array", "null"]
    },
    "values": { "type": ["object", "null"] }
  }
}
