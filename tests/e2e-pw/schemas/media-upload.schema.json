{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Media Upload Response",
  "type": "object",
  "required": ["success"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "data": {
      "type": "object",
      "properties": {
        "attribute": { "type": "string" },
        "category_field": { "type": "string" },
        "sku": { "type": "string" },
        "code": { "type": "string" },
        "filePath": { "type": "string", "minLength": 1 }
      }
    }
  }
}
