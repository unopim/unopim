{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@fixtures/*": ["fixtures/*"],
      "@utils/*": ["utils/*"],
      "@helpers/*": ["helpers/*"],
      "@constants/*": ["constants/*"],
      "@api/*": ["api/*"],
      "@database/*": ["database/*"]
    }
  },
  "include": ["**/*.ts"]
}
