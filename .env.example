APP_NAME=UnoPim
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_ADMIN_URL=admin

# Initial admin (used by AdminsTableSeeder on first boot only).
# Leave blank to auto-generate a random password and write it to
# storage/app/admin-credentials.txt — read it once, then delete.
# Existing admin rows are NEVER overwritten on re-seed.
INSTALLER_ADMIN_EMAIL=
INSTALLER_ADMIN_PASSWORD=

# Comma-separated list of upstream proxy IPs (or CIDRs) allowed to set
# X-Forwarded-* headers. Use '*' only if your edge already strips these
# headers from the public internet. Defaults to '127.0.0.1' when unset.
TRUSTED_PROXIES=127.0.0.1

# Optional extra hostnames that should be accepted in the Host header
# in addition to APP_URL (comma-separated, no scheme). Subdomains of
# APP_URL are accepted automatically.
TRUSTED_HOSTS=
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en_US
APP_CURRENCY=USD

VITE_HOST=
VITE_PORT=

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_PREFIX=

BROADCAST_CONNECTION=log
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS=admin@example.com
MAIL_FROM_NAME=

ADMIN_MAIL_ADDRESS=
ADMIN_MAIL_NAME=

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

QUEUE_CONNECTION=database

ELASTICSEARCH_ENABLED=
ELASTICSEARCH_CONNECTION=
ELASTICSEARCH_HOST=
ELASTICSEARCH_USER=
ELASTICSEARCH_PASS=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_CLOUD_ID=
ELASTICSEARCH_INDEX_PREFIX=

ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=3600

IMPORT_BATCH_SIZE=1000
IMPORT_BULK_CHUNK_SIZE=500
IMPORT_DEFERRED_INDEXING=false
COMPLETENESS_QUEUE=completeness

MICROSOFT_SSO_ENABLED=false
MICROSOFT_SSO_TENANT=
MICROSOFT_SSO_CLIENT_ID=
MICROSOFT_SSO_CLIENT_SECRET=
