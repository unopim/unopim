  "channel_derivations": {
    "_note": "Rules the seeder uses to derive non-canonical channel content from the ecommerce canonical.",
    "mobile_app": {
      "rule": "truncate_short_description_to_120_chars",
      "name_rule": "strip_trailing_descriptor_after_em_dash"
    },
    "print_catalogue": {
      "rule": "uppercase_name_prepend_brand",
      "include_attributes": ["pack_count_or_net_weight", "shelf_life", "case_quantity"],
      "price_discount": 0.05
    },
    "b2b_wholesale": {
      "rule": "technical_spec_focus",
      "include_attributes": ["case_quantity", "gtin_14", "lead_time_days", "minimum_order_quantity_cases", "country_of_origin"],
      "name_rule": "uppercase_with_case_suffix"
    }
  },

  "locale_mechanical_rules": {
    "_note": "en_US -> en_GB transform rules applied by the seeder when en_GB is missing.",
    "en_GB": {
      "spelling_swaps": {
